<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.ArcSSH.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_bg</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_arc_logo</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/splash_bg</item>
        <item name="postSplashScreenTheme">@style/Theme.ArcSSH</item>
    </style>

    <style name="Theme.ArcSSH" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/surface_shell</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">true</item>
    </style>
</resources>
